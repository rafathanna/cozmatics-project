rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Helper to check if is Admin
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'admin@gmail.com' || 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // 2. User Profiles
    match /users/{userId} {
      allow read, write: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // 3. Store Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 4. Products
    match /products/{product} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 5. Orders (Admin manages all, users create & read their own)
    match /orders/{order} {
      allow create: if true; 
      allow read: if request.auth != null && (isAdmin() || request.auth.token.email == resource.data.customerEmail);
      allow write: if isAdmin();
    }

    // 6. Coupons
    match /coupons/{coupon} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 7. Request / Contact Form
    match /requests/{requestDoc} {
      allow create: if true;
      allow read, write: if isAdmin();
    }

    // 8. Reviews
    match /reviews/{review} {
      allow read: if true;
      allow create: if request.auth != null 
                    && request.resource.data.rating >= 1 
                    && request.resource.data.rating <= 5
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
    }

    // 9. Live Chat System
    match /chats/{chatId} {
      allow read, write: if true;
    }
    match /messages/{msgId} {
      allow read, create: if true;
      allow update, delete: if isAdmin();
    }

    // 10. Protect everything else
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
